  "publicApiSurface": [
    "POST /auth/register - Register new user",
    "POST /auth/login - Authenticate user",
    "GET /api/conversations - List all conversations",
    "GET /api/conversations/{id}/messages - Get messages by conversation",
    "POST /api/conversations/{id}/messages - Send message to conversation",
    "ProcessTelegramUpdateUseCase - Process incoming Telegram updates",
    "RegisterUserUseCase - Register new users",
    "AuthenticateUserUseCase - Authenticate users",
    "SendMessageUseCase - Send messages to conversations",
    "ListConversationsUseCase - List user conversations"
